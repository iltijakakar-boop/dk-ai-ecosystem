# Project Settings
PROJECT_NAME="DK AI Ecosystem"
API_V1_STR="/api/v1"
ENVIRONMENT=development

# CORS Configuration (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# Database Configuration
# SQLite example: sqlite:///./sql_app.db
# PostgreSQL example: postgresql://postgres:postgres@localhost:5432/dk_ai_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dk_ai_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security Settings
# Generate a secure key e.g. using `openssl rand -hex 32`
SECRET_KEY=your-super-secret-key-change-it-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Core Configuration
AI_PROVIDER=gemini
DEFAULT_MODEL=gemini-2.5-flash
API_TIMEOUT=30
MAX_CONTEXT_LENGTH=8192
MAX_OUTPUT_TOKENS=2048

# Provider API Keys & Endpoints
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

